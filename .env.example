SOFIA_CKAN_BASE_URL=https://urbandata.sofia.bg
HOST=127.0.0.1
PORT=3000
MCP_HTTP_PATH=/mcp
REQUEST_TIMEOUT_MS=30000
PREVIEW_MAX_BYTES=262144
MAX_SEARCH_RESULTS=50
# How long (ms) to cache CKAN reads (groups, organizations, search, dataset lookups) in memory. Set to 0 to disable caching.
CACHE_TTL_MS=300000
# Comma-separated extra hostnames/origins (beyond 127.0.0.1/localhost) allowed to reach
# the MCP endpoint, e.g. a deployed Cloud Run hostname such as sofia-data-mcp-XXXXX.europe-west1.run.app.
# Leave unset for local-only development.
ALLOWED_HOSTS=
ALLOWED_ORIGINS=
# The URL of the upstream MCP server to which the proxy will forward requests. Used when running both server and client locally.
MCP_UPSTREAM_URL=http://127.0.0.1:3000/mcp
CLI_REQUEST_TIMEOUT_MS=30000
# The URL of the MCP server to which the client will send requests. Used when running the client separately from the server.
MCP_SERVER_URL=http://127.0.0.1:3000/mcp
