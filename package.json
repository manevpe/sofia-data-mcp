{
  "name": "sofia-data",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.8.1",
  "devDependencies": {
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "overrides": {
      "hono": "^4.12.30",
      "qs": "^6.15.3",
      "fast-uri": "^3.1.3",
      "ip-address": "^10.2.0"
    }
  },
  "scripts": {
    "build": "pnpm -r --workspace-concurrency=1 build",
    "check": "pnpm -r --workspace-concurrency=1 typecheck",
    "dev:server": "pnpm --filter @sofia-data/http-server dev",
    "dev:bridge": "pnpm --filter @sofia-data/stdio-bridge dev",
    "dev:cli": "pnpm --filter @sofia-data/cli dev",
    "test": "pnpm -r --workspace-concurrency=1 test"
  }
}
